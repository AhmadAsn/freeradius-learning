# =============================================================================
# .env — Environment Variables for FreeRADIUS Docker Stack
# =============================================================================
# Copy to .env and change EVERY value marked CHANGE_ME before deploying.
# Generate strong passwords: openssl rand -base64 24
# =============================================================================

# --- Database ---
DB_ROOT_PASSWORD=CHANGE_ME_root_pw_X9k2mB7v
DB_NAME=radius
DB_USER=radius
DB_PASSWORD=CHANGE_ME_radius_pw_Qp4nT8zW
DB_EXTERNAL_PORT=3307

# --- FreeRADIUS ---
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_CLIENTS_SECRET=CHANGE_ME_default_client_secret_Hj5rK3nM
RADIUS_DEBUG=false

# --- TLS Certificate Generation (optional, for auto-generated self-signed) ---
# CERT_CA_CN=FreeRADIUS CA
# CERT_SERVER_CN=radius.local
# CERT_ORG=FreeRADIUS Docker
# CERT_COUNTRY=US
# CERT_STATE=California
# CERT_CITY=San Francisco
# CERT_DAYS_CA=3650
# CERT_DAYS_SERVER=825
# DH_BITS=2048

# --- Database Maintenance ---
# ACCT_RETENTION_DAYS=365
# POSTAUTH_RETENTION_DAYS=90

# --- daloRADIUS (management UI) ---
DALORADIUS_PORT=8000

# --- Timezone ---
TZ=UTC
